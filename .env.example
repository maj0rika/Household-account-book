# Supabase Postgres connection string
DATABASE_URL=

# Better Auth secret (Phase 3)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# LLM Configuration (Phase 4)
# Manual provider override when an explicit provider is not passed
# Supported: "minimax", "kimi", "fireworks"
LLM_PROVIDER=kimi
# Legacy OpenAI key slot (currently unused by runtime parser)
OPENAI_API_KEY=
# KIMI API key (required when LLM_PROVIDER=kimi)
KIMI_API_KEY=
# Fireworks AI API key (fast Kimi K2.5 hosted on US servers)
FIREWORKS_API_KEY=
# MiniMax API key (short text routing)
MINIMAX_API_KEY=

# Field-level encryption key (32 bytes = 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Public API base URL
NEXT_PUBLIC_API_URL=

# Google Play review account bootstrap
REVIEW_ACCOUNT_EMAIL=googleplay-review@test.com
REVIEW_ACCOUNT_NAME="Google Play Reviewer"
REVIEW_ACCOUNT_PASSWORD=
